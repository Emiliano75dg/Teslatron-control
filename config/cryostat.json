{
  "cryostat": {
    "backend": "mock",
    "read_only": false,
    "active_insert": "fisher_probe",
    "poll_interval_s": 1.0,
    "log_interval_s": 20.0,
    "log_path": "data/cryostat_environment.csv",
    "insert_profiles": {
      "fisher_probe": {
        "name": "Fisher probe",
        "description": "Default cryostat configuration for the Fisher probe insert.",
        "sample_thermometer": "",
        "sample_sensor": {
          "sensor_type": "",
          "excitation_type": "",
          "excitation_magnitude": "",
          "calibration": "X205007"
        },
        "capabilities": {
          "temperature_control": true,
          "sample_loop": true,
          "vti_loop": true,
          "gas_control": true,
          "field_control": true,
          "pid_control": true,
          "fixed_heater": true
        }
      },
      "heliox_probe": {
        "name": "Heliox probe",
        "description": "Cryostat configuration for the Heliox probe insert.",
        "sample_thermometer": "",
        "sample_sensor": {
          "sensor_type": "",
          "excitation_type": "",
          "excitation_magnitude": "",
          "calibration": ""
        },
        "capabilities": {
          "temperature_control": true,
          "sample_loop": true,
          "vti_loop": true,
          "gas_control": true,
          "field_control": true,
          "pid_control": true,
          "fixed_heater": true
        }
      },
      "basic_probe": {
        "name": "Basic probe",
        "description": "Cryostat configuration for the Basic probe insert.",
        "sample_thermometer": "Basic probe thermometer",
        "sample_sensor": {
          "sensor_type": "",
          "excitation_type": "",
          "excitation_magnitude": "",
          "calibration": "X213221"
        },
        "capabilities": {
          "temperature_control": true,
          "sample_loop": true,
          "vti_loop": true,
          "gas_control": true,
          "field_control": true,
          "pid_control": true,
          "fixed_heater": true
        }
      }
    },
    "itc": {
      "address": "ASRL7::INSTR",
      "timeout_ms": 3000,
      "read_termination": "\n",
      "write_termination": "\n",
      "probe_signal": "DB8.T1",
      "probe_loop": "DB8.T1",
      "vti_signal": "MB1.T1",
      "vti_loop": "MB1.T1",
      "pressure": "DB5.P1"
    },
    "ips": {
      "address": "ASRL8::INSTR",
      "timeout_ms": 3000,
      "read_termination": "\n",
      "write_termination": "\n",
      "magnet_group": "GRPZ",
      "magnet_temperature": "MB1.T1",
      "pt1_temperature": "DB8.T1",
      "pt2_temperature": "DB7.T1",
      "switch_on_delay_s": 300.0,
      "switch_off_delay_s": 300.0
    },
    "safety": {
      "min_temperature_K": 0.0,
      "max_temperature_K": 350.0,
      "max_temperature_rate_K_per_min": 5.0,
      "max_field_T": 12.0,
      "max_field_rate_T_per_min": 0.5
    }
  }
}
