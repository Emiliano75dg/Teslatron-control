{
  "cryostat": {
    "backend": "mercury",
    "read_only": false,
    "enable_shutdown": true,
    "active_insert": "fisher_probe",
    "active_sample_sensor": "fisher_cernox",
    "poll_interval_s": 1.0,
    "log_interval_s": 20.0,
    "log_dir": "data",
    "recipe_dir": "data/recipes",
    "sample_sensor_presets": {
      "fisher_cernox": {
        "sensor_type": "CERNOX",
        "excitation_type": "CURR",
        "excitation_magnitude": "10uA",
        "calibration": "X205007"
      },
      "basic_cernox": {
        "sensor_type": "CERNOX",
        "excitation_type": "CURR",
        "excitation_magnitude": "10uA",
        "calibration": "X213221"
      }
    },
    "insert_profiles": {
      "fisher_probe": {
        "name": "Fisher probe",
        "description": "Offline Mercury GUI profile for local frontend checks without real hardware. Commands stay local and fail harmlessly against loopback endpoints.",
        "sample_thermometer": "",
        "sample_sensor_options": ["fisher_cernox"],
        "default_sample_sensor": "fisher_cernox",
        "capabilities": {
          "temperature_control": true,
          "sample_loop": true,
          "vti_loop": true,
          "gas_control": true,
          "field_control": true,
          "pid_control": true,
          "fixed_heater": true
        }
      },
      "basic_probe": {
        "name": "Basic probe",
        "description": "Offline Mercury secondary profile for local GUI checks.",
        "sample_thermometer": "Basic probe thermometer",
        "sample_sensor_options": ["basic_cernox"],
        "default_sample_sensor": "basic_cernox",
        "capabilities": {
          "temperature_control": true,
          "sample_loop": true,
          "vti_loop": true,
          "gas_control": true,
          "field_control": true,
          "pid_control": true,
          "fixed_heater": true
        }
      }
    },
    "itc": {
      "address": "TCPIP0::127.0.0.1::65001::SOCKET",
      "timeout_ms": 100,
      "read_termination": "\n",
      "write_termination": "\n",
      "probe_signal": "DB8.T1",
      "probe_loop": "DB8.T1",
      "vti_signal": "MB1.T1",
      "vti_loop": "MB1.T1",
      "pressure": "DB5.P1"
    },
    "ips": {
      "address": "TCPIP0::127.0.0.1::65002::SOCKET",
      "timeout_ms": 100,
      "read_termination": "\n",
      "write_termination": "\n",
      "magnet_group": "GRPZ",
      "magnet_temperature": "MB1.T1",
      "pt1_temperature": "DB8.T1",
      "pt2_temperature": "DB7.T1",
      "switch_on_delay_s": 300.0,
      "switch_off_delay_s": 300.0,
      "command_delay_s": 0.1
    },
    "safety": {
      "min_temperature_K": 0.0,
      "max_temperature_K": 350.0,
      "max_temperature_rate_K_per_min": 5.0,
      "max_field_T": 12.0,
      "max_field_rate_T_per_min": 0.5
    }
  }
}
